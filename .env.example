PORT=5000
NODE_ENV=development

MONGO_DB_URI=mongodb://localhost:27017/task-manager

# JWT/session settings
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=1d
SESSION_DURATION=86400

# Redis: prefer URL for cloud or Docker setups
REDIS_URL=redis://127.0.0.1:6379

# Optional host/port fallback when REDIS_URL is not provided
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
